// ============================================================
// LIST models
// ============================================================

model BoardList {
  id          String   @id @default(cuid())
  board_id    String
  name        String
  position    Float
  is_archived Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  board Board  @relation(fields: [board_id], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([board_id])
  @@index([position])
  @@map("board_lists")
}
