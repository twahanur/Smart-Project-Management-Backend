{
  "info": {
    "name": "Trello-Style Workspace Board System API",
    "description": "Premium Trello-Style Board, Workspace, List, Card, Checklist, Label, and Attachment API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "listId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "checklistId", "value": "" },
    { "key": "itemId", "value": "" },
    { "key": "labelId", "value": "" },
    { "key": "commentId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "customFieldId", "value": "" },
    { "key": "attachmentId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Developer\",\n  \"email\": \"jane.dev@example.com\",\n  \"password\": \"Jane@1234\",\n  \"role\": \"team_member\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  // refreshToken is set via httpOnly cookie by the server.",
                "  // If testing without cookies, manually set it from Set-Cookie header.",
                "  const cookieHeader = pm.response.headers.get('Set-Cookie') || '';",
                "  const match = cookieHeader.match(/refreshToken=([^;]+)/);",
                "  if (match) pm.collectionVariables.set('refreshToken', match[1]);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Server reads refreshToken from httpOnly cookie automatically. Body fallback is also supported if cookie is unavailable."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  pm.test('Access token refreshed successfully', () => {",
                "    pm.expect(res.data).to.have.property('accessToken');",
                "  });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Demo Login (PM)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/demo-login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"project_manager\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  const cookieHeader = pm.response.headers.get('Set-Cookie') || '';",
                "  const match = cookieHeader.match(/refreshToken=([^;]+)/);",
                "  if (match) pm.collectionVariables.set('refreshToken', match[1]);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Demo Login (Member)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/demo-login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"team_member\"\n}" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                "  const cookieHeader = pm.response.headers.get('Set-Cookie') || '';",
                "  const match = cookieHeader.match(/refreshToken=([^;]+)/);",
                "  if (match) pm.collectionVariables.set('refreshToken', match[1]);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
