{
  "info": {
    "name": "User Module API Collection",
    "description": "Postman collection for the refactored User module endpoints including profile retrieval, updates, preferences, search, pagination, and roles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "👥 Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Get My Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me/tasks"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Developer Updated\",\n  \"bio\": \"Senior developer working on workspace features.\",\n  \"avatar_url\": \"https://images.unsplash.com/photo-1534528741775-53994a69daeb\"\n}"
            }
          }
        },
        {
          "name": "Update My Preferences",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/me/preferences",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"dark\",\n  \"email_notifications\": true\n}"
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/search?q=demo"
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users?page=1&limit=10"
          }
        },
        {
          "name": "Update User Role (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/PASTE_USER_ID_HERE/role",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"project_manager\"\n}"
            }
          }
        }
      ]
    }
  ]
}
